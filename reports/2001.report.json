{
  "meta": {
    "id": "2001",
    "title": "DTC Performance vs Forecast",
    "asOfDate": "2026-03-08",
    "owner": "Merchandising & Planning",
    "description": "Weekly DTC performance analysis vs forecast for WE 3/8 (Fiscal Week 202609). Covers EC + Full-Price channels across all product classes, genders, and end uses."
  },

  "dataSources": {
    "execKpis": {
      "outputFile": "exec-kpis.json",
      "description": "Executive-level KPIs: total demand, forecast variance, YoY, return rate",
      "expectedRows": "1"
    },
    "weeklyTrend": {
      "outputFile": "weekly-trend.json",
      "description": "Weekly demand vs forecast vs LY trend across all 5 fiscal weeks",
      "expectedRows": "5"
    },
    "channelPerformance": {
      "outputFile": "channel-performance.json",
      "description": "EC vs FP channel performance: demand, forecast, units, returns",
      "expectedRows": "2"
    },
    "channelWeeklyTrend": {
      "outputFile": "channel-weekly-trend.json",
      "description": "Weekly demand trend by channel (EC and FP separately)",
      "expectedRows": "~10"
    },
    "productClassPerformance": {
      "outputFile": "product-class-performance.json",
      "description": "Product class vs forecast: actual, fcst, gap, YoY for all classes",
      "expectedRows": "~10"
    },
    "subclassPerformance": {
      "outputFile": "subclass-performance.json",
      "description": "Sub-class level vs forecast with return rates",
      "expectedRows": "~40"
    },
    "styleWinners": {
      "outputFile": "style-winners.json",
      "description": "Top 20 styles beating forecast by $ gap",
      "expectedRows": "20"
    },
    "styleMisses": {
      "outputFile": "style-misses.json",
      "description": "Top 20 styles missing forecast by $ gap",
      "expectedRows": "20"
    },
    "genderPerformance": {
      "outputFile": "gender-performance.json",
      "description": "Gender-level performance vs forecast",
      "expectedRows": "3"
    },
    "endUsePerformance": {
      "outputFile": "end-use-performance.json",
      "description": "End use vs forecast: demand, fcst gap, YoY",
      "expectedRows": "~5"
    },
    "fcstGapByChannel": {
      "outputFile": "fcst-gap-by-channel.json",
      "description": "Forecast gap decomposition by channel",
      "expectedRows": "2"
    },
    "fcstGapByGender": {
      "outputFile": "fcst-gap-by-gender.json",
      "description": "Forecast gap decomposition by gender",
      "expectedRows": "3"
    },
    "fcstGapByEndUse": {
      "outputFile": "fcst-gap-by-end-use.json",
